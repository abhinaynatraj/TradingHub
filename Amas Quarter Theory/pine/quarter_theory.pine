//@version=6
indicator("Abhi's Live Price Action", overlay=true,
         max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║ Abhi's Live Price Action — bootcamp price-action overlay                 ║
// ║ 15m quarters · 1h doji/line · 3h triad line/apex · 05-box bands · midlns ║
// ║                                                                          ║
// ║ NOTE: This is the v1 visual-only build. Probability readouts display     ║
// ║ "—" placeholders; empirical tables wired in a follow-up release.         ║
// ╚══════════════════════════════════════════════════════════════════════════╝


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║ 1. SETTINGS                                                              ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// ── ⚙ General ─────────────────────────────────────────────────────────────
G_GENERAL = "⚙ General"
gTheme        = input.string("Dark", "Theme",        options=["Dark","Light","Custom"], group=G_GENERAL)
gDataSource   = input.string("Auto", "Empirical data source (reserved)", options=["Auto","NQ","ES"], group=G_GENERAL,
                              tooltip="Reserved for empirical-table phase. Currently inert.")
gTzNote       = input.string("America/New_York", "Time zone (read-only)", options=["America/New_York"], group=G_GENERAL)

// ── 📊 Live Readouts ─────────────────────────────────────────────────────
G_RO = "📊 Live Readouts"
gReadoutsOn   = input.bool(true,  "▶ Enable group", group=G_RO)
gShow1h       = input.bool(true,  "Show 1h hour tint box", group=G_RO)
gShow3h       = input.bool(false, "Show 3h triad tint box", group=G_RO)
gActiveStyle  = input.string("Highlighted + LIVE tag", "Active block style",
                              options=["Highlighted","LIVE tag","Highlighted + LIVE tag"], group=G_RO)
gHistDepth    = input.int(20, "History depth (triads)", minval=1, maxval=40, group=G_RO)
gShowN        = input.bool(true,  "Show sample count (n)", group=G_RO)
gConfColor    = input.bool(true,  "Confidence color on n", group=G_RO)
gShowPath     = input.bool(true,  "Show conditional path %", group=G_RO)
gShowQPair    = input.bool(true,  "Show quarter-pair recommendation", group=G_RO)

// ── 🕐 Quarter Structure ─────────────────────────────────────────────────
G_QS = "🕐 Quarter Structure"
gQStructOn    = input.bool(true,  "▶ Enable group", group=G_QS)
gShowQDiv     = input.bool(true,  "Show quarter dividers (vertical dotted)", group=G_QS)
gShowInStat   = input.bool(true,  "Show in-stat extreme labels (Q1/Q4)", group=G_QS)
gShowOutStat  = input.bool(true,  "Show out-of-stat extreme labels (Q2/Q3)", group=G_QS)
gShowSweepers = input.bool(true,  "Show sweeper markers", group=G_QS)
gShowBiasShift= input.bool(true,  "Show bias-shift markers", group=G_QS)
gShowDojiConf = input.bool(true,  "Show doji-confirmed marker", group=G_QS)
gShowQBgs     = input.bool(true,  "Show per-quarter background tints", group=G_QS)
// Per-quarter background colors. Q1/Q2/Q4 default to fully transparent so the
// hour shows as clear; Q3 defaults to a faint cyan/teal wash so the eye picks
// it out (cyan kept distinct from the amber 05 box). All user-configurable.
gColQ1Bg      = input.color(color.new(color.white, 100), "Q1 background", group=G_QS)
gColQ2Bg      = input.color(color.new(color.white, 100), "Q2 background", group=G_QS)
gColQ3Bg      = input.color(color.new(#67e8f9, 90),       "Q3 background", group=G_QS)
gColQ4Bg      = input.color(color.new(color.white, 100), "Q4 background", group=G_QS)

// ── 🕒 Hour & Triad Verdicts ─────────────────────────────────────────────
G_VER = "🕒 Hour & Triad Verdicts"
gVerdictsOn   = input.bool(true,  "▶ Enable group", group=G_VER)
gShowHourVerd = input.bool(true,  "Show hour close verdict", group=G_VER)
gShowTriadVerd= input.bool(true,  "Show triad close verdict", group=G_VER)
gShowApexHr   = input.bool(true,  "Show apex-hour highlight", group=G_VER)
gShowOhlcOver = input.bool(true,  "Show 3h running OHLC overlay", group=G_VER)

// ── 📐 Midlines ───────────────────────────────────────────────────────────
G_MID = "📐 Midlines"
gMidOn        = input.bool(true,  "▶ Enable group", group=G_MID)
gShowMid1h    = input.bool(true,  "Show 1h midline", group=G_MID)
gShowMid3h    = input.bool(true,  "Show 3h midline", group=G_MID)
gShowMidReact = input.bool(false, "Show midline reaction markers", group=G_MID)
gMid1hWidth   = input.int(1, "1h midline width", minval=1, maxval=4, group=G_MID)
gMid3hWidth   = input.int(1, "3h midline width", minval=1, maxval=4, group=G_MID)

// ── 📦 05 Box & Bands ─────────────────────────────────────────────────────
G_BOX = "📦 05 Box & Bands"
gBoxOn        = input.bool(true,  "▶ Enable group", group=G_BOX)
gShowBoxCol   = input.bool(true,  "Show 05 box column (full-height tint)", group=G_BOX)
gShowBand05   = input.bool(true,  "Show ±0.05% bands", group=G_BOX)
gShowBand10   = input.bool(true,  "Show ±0.10% bands", group=G_BOX)
gShowBandRej  = input.bool(true,  "Show band rejection markers", group=G_BOX)
gShowBandLbl  = input.bool(true,  "Show inline % labels (.05% / .1%)", group=G_BOX)

// ── 🔔 Alerts ─────────────────────────────────────────────────────────────
G_AL = "🔔 Alerts"
gAlertsOn     = input.bool(true,  "▶ Enable group", group=G_AL)
gAlertSweep   = input.bool(false, "Alert on sweeper", group=G_AL)
gAlertDoji    = input.bool(true,  "Alert on doji-confirmed", group=G_AL)
gAlertApex    = input.bool(true,  "Alert on apex-confirmed", group=G_AL)
gAlertMid     = input.bool(false, "Alert on midline reaction", group=G_AL)
gAlertBandRej = input.bool(false, "Alert on band rejection", group=G_AL)

// ── 🎨 Custom Colors (only used when Theme = Custom) ─────────────────────
G_COL = "🎨 Custom Colors (active when Theme = Custom)"
gColInStat    = input.color(color.new(#7eb6ff, 0),  "In-stat extreme (navy)", group=G_COL)
gColOutStat   = input.color(color.new(#f59e0b, 0),  "Out-of-stat extreme",  group=G_COL)
gColSweeper   = input.color(color.new(#8b5cf6, 0),  "Sweeper",              group=G_COL)
gColDojiConf  = input.color(color.new(#f59e0b, 0),  "Doji-confirmed",       group=G_COL)
gColApexHr    = input.color(color.new(#ef4444, 0),  "Apex-hour highlight",  group=G_COL)
gColLineUp    = input.color(color.new(#10b981, 0),  "Line-up readout",      group=G_COL)
gColLineDn    = input.color(color.new(#ef4444, 0),  "Line-down readout",    group=G_COL)
gColApexUp    = input.color(color.new(#3b82f6, 0),  "Apex-up readout",      group=G_COL)
gColApexDn    = input.color(color.new(#8b5cf6, 0),  "Apex-down readout",    group=G_COL)
gColDojiRO    = input.color(color.new(#f59e0b, 0),  "Doji readout",         group=G_COL)
gColMid1h     = input.color(color.new(#f59e0b, 0),  "1h midline",           group=G_COL)
gColMid3h     = input.color(color.new(#e2eaf4, 0),  "3h midline",           group=G_COL)
gColBand05    = input.color(color.new(#ffffff, 75), "0.05% band",           group=G_COL)
gColBand10    = input.color(color.new(#ffffff, 50), "0.10% band",           group=G_COL)
gColBoxTint   = input.color(color.new(#ffffff, 94), "05 box tint",          group=G_COL)
gColActiveHr  = input.color(color.new(#06b6d4, 95), "Active hour tint",     group=G_COL)
gColActiveTr  = input.color(color.new(#06b6d4, 97), "Active triad tint",    group=G_COL)
gColQDiv      = input.color(color.new(#ffffff, 88), "Quarter divider",      group=G_COL)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║ 2. THEME RESOLVER                                                        ║
// ╚══════════════════════════════════════════════════════════════════════════╝

type Theme
    color in_stat
    color out_stat
    color sweeper
    color doji_conf
    color apex_hour
    color line_up
    color line_dn
    color apex_up
    color apex_dn
    color doji
    color mid_1h
    color mid_3h
    color band_05
    color band_10
    color box_tint
    color active_hr
    color active_triad
    color q_div
    color readout_bg
    color readout_border
    color readout_text
    color readout_text_dim
    color readout_active_accent
    color conf_high
    color conf_med
    color conf_low

resolveTheme() =>
    Theme t = na
    if gTheme == "Dark"
        t := Theme.new(
          // In-stat: light navy in Dark mode for legibility against dark bg
          // (the user spec said "dark navy"; we keep navy hue, lighten value)
          in_stat              = color.new(#7eb6ff, 0),
          out_stat             = color.new(#f59e0b, 0),
          sweeper              = color.new(#8b5cf6, 0),
          doji_conf            = color.new(#f59e0b, 0),
          apex_hour            = color.new(#ef4444, 0),
          line_up              = color.new(#10b981, 0),
          line_dn              = color.new(#ef4444, 0),
          apex_up              = color.new(#3b82f6, 0),
          apex_dn              = color.new(#8b5cf6, 0),
          doji                 = color.new(#a78bfa, 0),       // violet (distinct from amber)
          mid_1h               = color.new(#f59e0b, 0),       // amber
          mid_3h               = color.new(#06b6d4, 0),       // cyan, distinct from amber
          band_05              = color.new(#ffffff, 60),
          band_10              = color.new(#ffffff, 30),
          box_tint             = color.new(#fcd34d, 90),       // 05 box bg: soft amber (distinct from neutral gray)
          active_hr            = color.new(#cbd5e1, 100),      // clear by default
          active_triad         = color.new(#cbd5e1, 88),       // slightly more visible than active hour
          q_div                = color.new(#ffffff, 100),     // hour box bg: clear by default
          readout_bg           = color.new(#1a2235, 5),        // bg-raised, near-opaque
          readout_border       = color.new(#ffffff, 75),
          readout_text         = color.new(#e2eaf4, 0),
          readout_text_dim     = color.new(#8ba4bc, 0),
          readout_active_accent= color.new(#06b6d4, 65),
          conf_high            = color.new(#10b981, 0),
          conf_med             = color.new(#f59e0b, 0),
          conf_low             = color.new(#ef4444, 0))
    else if gTheme == "Light"
        t := Theme.new(
          in_stat              = color.new(#0a2540, 0),  // dark navy
          out_stat             = color.new(#d97706, 0),
          sweeper              = color.new(#7c3aed, 0),
          doji_conf            = color.new(#d97706, 0),
          apex_hour            = color.new(#dc2626, 0),
          line_up              = color.new(#059669, 0),
          line_dn              = color.new(#dc2626, 0),
          apex_up              = color.new(#2563eb, 0),
          apex_dn              = color.new(#7c3aed, 0),
          doji                 = color.new(#7c3aed, 0),       // violet (distinct from amber)
          mid_1h               = color.new(#d97706, 0),       // amber
          mid_3h               = color.new(#0891b2, 0),       // cyan, distinct from amber
          band_05              = color.new(#000000, 55),
          band_10              = color.new(#000000, 25),
          box_tint             = color.new(#f59e0b, 88),       // 05 box bg: soft amber (distinct from neutral gray)
          active_hr            = color.new(#94a3b8, 100),      // clear by default
          active_triad         = color.new(#94a3b8, 86),       // more opaque than active hour
          q_div                = color.new(#94a3b8, 100),      // hour box bg: clear by default
          readout_bg           = color.new(#f1f5f9, 5),        // slate-100 fill, near-opaque
          readout_border       = color.new(#475569, 50),
          readout_text         = color.new(#0f172a, 0),        // near-black for readability
          readout_text_dim     = color.new(#475569, 0),
          readout_active_accent= color.new(#0891b2, 55),
          conf_high            = color.new(#059669, 0),
          conf_med             = color.new(#d97706, 0),
          conf_low             = color.new(#dc2626, 0))
    else
        t := Theme.new(
          in_stat              = gColInStat,
          out_stat             = gColOutStat,
          sweeper              = gColSweeper,
          doji_conf            = gColDojiConf,
          apex_hour            = gColApexHr,
          line_up              = gColLineUp,
          line_dn              = gColLineDn,
          apex_up              = gColApexUp,
          apex_dn              = gColApexDn,
          doji                 = gColDojiRO,
          mid_1h               = gColMid1h,
          mid_3h               = gColMid3h,
          band_05              = gColBand05,
          band_10              = gColBand10,
          box_tint             = gColBoxTint,
          active_hr            = gColActiveHr,
          active_triad         = gColActiveTr,
          q_div                = gColQDiv,
          readout_bg           = color.new(#111827, 15),
          readout_border       = color.new(#ffffff, 90),
          readout_text         = color.new(#e2eaf4, 0),
          readout_text_dim     = color.new(#8ba4bc, 0),
          readout_active_accent= color.new(#06b6d4, 65),
          conf_high            = color.new(#10b981, 0),
          conf_med             = color.new(#f59e0b, 0),
          conf_low             = color.new(#ef4444, 0))
    t

var Theme T = na
T := resolveTheme()


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║ 3. TIME / STRUCTURE PRIMITIVES                                           ║
// ╚══════════════════════════════════════════════════════════════════════════╝

NY_TZ = "America/New_York"

// ── Script-level constants (computed once at script init) ─────────────────
// `timeframe.in_seconds("")` returns a constant for the chart's TF, so we
// pre-compute the bar counts that are reused all over the rendering blocks.
int TF_SEC          = timeframe.in_seconds("")
int BARS_PER_HOUR   = math.max(1, int(60 * 60   / TF_SEC))
int BARS_PER_QUARTER= math.max(1, int(15 * 60   / TF_SEC))
bool IS_TF_MIN1     = TF_SEC == 60
bool IS_TF_MIN1OR5  = TF_SEC <= 300

// ── Per-bar time cache ────────────────────────────────────────────────────
// `hour(...)` and `minute(...)` with a tz argument do non-trivial work each
// call. Call them once per bar and cache the results — every predicate
// below is a pure arithmetic test against the cache.
int _H = hour(time, NY_TZ)
int _M = minute(time, NY_TZ)

quarterOfHour()    => int(math.floor(_M / 15)) + 1
isFirstBarOfQuarter() => _M == 0  or _M == 15 or _M == 30 or _M == 45
isLastBarOfQuarter()  => _M == 14 or _M == 29 or _M == 44 or _M == 59
isBoxBar()         => _M <= 4
isHourClose()      => _M == 59
isTfMin1()         => IS_TF_MIN1
isTfMin1or5()      => IS_TF_MIN1OR5

blockId() =>
    string b = na
    if _H < 3
        b := "00-03"
    else if _H < 6
        b := "03-06"
    else if _H < 9
        b := "06-09"
    else if _H < 12
        b := "09-12"
    else if _H < 15
        b := "12-15"
    else if _H >= 18 and _H < 21
        b := "18-21"
    else if _H >= 21
        b := "21-00"
    b

hourIndexInTriad() =>
    int idx = na
    if _H < 3
        idx := _H + 1
    else if _H < 6
        idx := _H - 2
    else if _H < 9
        idx := _H - 5
    else if _H < 12
        idx := _H - 8
    else if _H < 15
        idx := _H - 11
    else if _H >= 18 and _H < 21
        idx := _H - 17
    else if _H >= 21
        idx := _H - 20
    idx

isTriadClose() => isHourClose() and hourIndexInTriad() == 3


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║ 4. RUNNING AGGREGATIONS                                                  ║
// ╚══════════════════════════════════════════════════════════════════════════╝

type QuarterAgg
    int    qIdx
    int    anchorBar
    float  open_   = na
    float  close_  = na
    float  high_   = na
    float  low_    = na
    int    highBar = na
    int    lowBar  = na
    int    barCount = 0

quarterUpdate(QuarterAgg q, float o, float h, float l, float c) =>
    if not na(q)
        if q.barCount == 0
            q.open_ := o
        q.close_ := c
        // Use >= so equal-high re-touches advance highBar to the most recent
        // bar holding the extreme. Better matches the eye for live tracking
        // when price retests an earlier high within the same quarter.
        if na(q.high_) or h >= q.high_
            q.high_   := h
            q.highBar := bar_index
        if na(q.low_) or l <= q.low_
            q.low_   := l
            q.lowBar := bar_index
        q.barCount += 1

type HourAgg
    int        anchorBar
    QuarterAgg q1 = na
    QuarterAgg q2 = na
    QuarterAgg q3 = na
    QuarterAgg q4 = na
    float      box05Hi = na
    float      box05Lo = na
    bool       box05Locked = false

hourHigh(HourAgg h) =>
    float hi = na
    if not na(h.q1) and (na(hi) or h.q1.high_ > hi)
        hi := h.q1.high_
    if not na(h.q2) and (na(hi) or h.q2.high_ > hi)
        hi := h.q2.high_
    if not na(h.q3) and (na(hi) or h.q3.high_ > hi)
        hi := h.q3.high_
    if not na(h.q4) and (na(hi) or h.q4.high_ > hi)
        hi := h.q4.high_
    hi

hourLow(HourAgg h) =>
    float lo = na
    if not na(h.q1) and (na(lo) or h.q1.low_ < lo)
        lo := h.q1.low_
    if not na(h.q2) and (na(lo) or h.q2.low_ < lo)
        lo := h.q2.low_
    if not na(h.q3) and (na(lo) or h.q3.low_ < lo)
        lo := h.q3.low_
    if not na(h.q4) and (na(lo) or h.q4.low_ < lo)
        lo := h.q4.low_
    lo

type TriadAgg
    string  blockId
    int     anchorBar
    HourAgg c1 = na
    HourAgg c2 = na
    HourAgg c3 = na

triadHigh(TriadAgg t) =>
    float hi = na
    h1 = na(t.c1) ? na : hourHigh(t.c1)
    h2 = na(t.c2) ? na : hourHigh(t.c2)
    h3 = na(t.c3) ? na : hourHigh(t.c3)
    if not na(h1)
        hi := h1
    if not na(h2) and (na(hi) or h2 > hi)
        hi := h2
    if not na(h3) and (na(hi) or h3 > hi)
        hi := h3
    hi

triadLow(TriadAgg t) =>
    float lo = na
    l1 = na(t.c1) ? na : hourLow(t.c1)
    l2 = na(t.c2) ? na : hourLow(t.c2)
    l3 = na(t.c3) ? na : hourLow(t.c3)
    if not na(l1)
        lo := l1
    if not na(l2) and (na(lo) or l2 < lo)
        lo := l2
    if not na(l3) and (na(lo) or l3 < lo)
        lo := l3
    lo

// One TriadAgg per active 3h block. Reset at the start of each block.
var TriadAgg activeTriad = na

if isFirstBarOfQuarter() and quarterOfHour() == 1 and hourIndexInTriad() == 1
    activeTriad := TriadAgg.new(blockId = blockId(), anchorBar = bar_index)

// Standalone aggregator for the 3pm hour (15:00–15:59). Outside any triad
// block, but hour-level features still render. Triad-only features (3h
// midline, apex hour, triad verdict) are gated separately on activeTriad.
var HourAgg hour3pm = na
is3pmHour() => _H == 15

if isFirstBarOfQuarter() and quarterOfHour() == 1 and is3pmHour()
    hour3pm := HourAgg.new(anchorBar = bar_index)

// Lazy-create the triad hour for the current triad index. Returns the
// per-hour aggregator (or na if outside the triad's hour range).
ensureTriadHour() =>
    HourAgg h = na
    if not na(activeTriad)
        int hidx = hourIndexInTriad()
        if hidx == 1
            if na(activeTriad.c1)
                activeTriad.c1 := HourAgg.new(anchorBar = bar_index)
            h := activeTriad.c1
        else if hidx == 2
            if na(activeTriad.c2)
                activeTriad.c2 := HourAgg.new(anchorBar = bar_index)
            h := activeTriad.c2
        else if hidx == 3
            if na(activeTriad.c3)
                activeTriad.c3 := HourAgg.new(anchorBar = bar_index)
            h := activeTriad.c3
    h

// Returns the active per-hour aggregator (3pm standalone or triad's
// current-hour slot). Centralizes the dispatch so all rendering blocks
// share one code path. Pine UDTs are reference types, so the returned
// HourAgg can be mutated by callers.
liveHour() =>
    HourAgg h = na
    if is3pmHour()
        h := hour3pm
    else
        h := ensureTriadHour()
    h

hasLiveHour() => not na(liveHour())

// Per-bar aggregation for the active hour: lazy-create the current quarter,
// update its OHLC, and accumulate the 05-box. Idempotent across triad and
// 3pm paths since both share the HourAgg/QuarterAgg shape.
aggregateLiveHour() =>
    HourAgg h = liveHour()
    if not na(h)
        int qi = quarterOfHour()
        if qi == 1 and na(h.q1)
            h.q1 := QuarterAgg.new(qIdx = 1, anchorBar = bar_index)
        if qi == 2 and na(h.q2)
            h.q2 := QuarterAgg.new(qIdx = 2, anchorBar = bar_index)
        if qi == 3 and na(h.q3)
            h.q3 := QuarterAgg.new(qIdx = 3, anchorBar = bar_index)
        if qi == 4 and na(h.q4)
            h.q4 := QuarterAgg.new(qIdx = 4, anchorBar = bar_index)
        QuarterAgg q = qi == 1 ? h.q1 : qi == 2 ? h.q2 : qi == 3 ? h.q3 : h.q4
        if not na(q)
            if q.barCount == 0
                q.open_ := open
            q.close_ := close
            if na(q.high_) or high >= q.high_
                q.high_   := high
                q.highBar := bar_index
            if na(q.low_) or low <= q.low_
                q.low_   := low
                q.lowBar := bar_index
            q.barCount += 1
        if isBoxBar()
            h.box05Hi := na(h.box05Hi) ? high : math.max(h.box05Hi, high)
            h.box05Lo := na(h.box05Lo) ? low  : math.min(h.box05Lo, low)
            if _M == 4
                h.box05Locked := true

// Single per-bar aggregation entry point.
aggregateLiveHour()


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║ 5. CLASSIFIERS                                                           ║
// ╚══════════════════════════════════════════════════════════════════════════╝

classifyHour(HourAgg h) =>
    string cls = "pending"
    if not na(h) and not na(h.q1) and not na(h.q2) and not na(h.q3) and not na(h.q4)
        h1 = h.q1.high_, h2 = h.q2.high_, h3 = h.q3.high_, h4 = h.q4.high_
        l1 = h.q1.low_,  l2 = h.q2.low_,  l3 = h.q3.low_,  l4 = h.q4.low_
        if h1 < h2 and h2 < h3 and h3 < h4 and l1 < l2 and l2 < l3 and l3 < l4
            cls := "line-up"
        else if h1 > h2 and h2 > h3 and h3 > h4 and l1 > l2 and l2 > l3 and l3 > l4
            cls := "line-down"
        else
            cls := "doji"
    cls

classifyTriad(TriadAgg t) =>
    string cls = "pending"
    if not na(t) and not na(t.c1) and not na(t.c2) and not na(t.c3)
        h1 = hourHigh(t.c1), h2 = hourHigh(t.c2), h3 = hourHigh(t.c3)
        l1 = hourLow(t.c1),  l2 = hourLow(t.c2),  l3 = hourLow(t.c3)
        if not na(h1) and not na(h2) and not na(h3) and not na(l1) and not na(l2) and not na(l3)
            if h1 < h2 and h2 < h3 and l1 < l2 and l2 < l3
                cls := "line-up"
            else if h1 > h2 and h2 > h3 and l1 > l2 and l2 > l3
                cls := "line-down"
            else if h1 < h2 and h2 > h3
                cls := "apex-up"
            else if l1 > l2 and l2 < l3
                cls := "apex-down"
            else
                cls := "doji"
    cls


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║ 6. RENDERERS                                                             ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// ATR-based vertical offset used by labels positioned below price action.
atrOffset() => ta.atr(20) * 2.0

// Tolerance for "extreme" tie-breaking: the earliest quarter within one tick
// of the running hour high/low is treated as holding the extreme. Prevents a
// later quarter that nudges past the early high by a tick from stealing the
// label when the early quarter is what the eye reads as the high.
extremeEps() => syminfo.mintick

// True for any hour we render hour-level features on: triad-block hours OR
// the 3pm standalone hour. The 3-4pm and 4-5pm gap and overnight hours that
// fall outside both still return false.
inTrackedHour() => not na(blockId()) or is3pmHour()

// ── Hour box (bounded to hour range) + intra-hour quarter verticals ───────
// Hour box: tinted rectangle bounded by the hour's running high/low, growing
// with each bar. Quarter verticals at :15, :30, :45 are thin solid lines
// confined to within the active hour's price range.

// Hour box bg: clear by default. Pass `na` when q_div is at alpha ≥95 so
// the fill is truly invisible (Pine's `color.new(c, 100)` can paint a faint
// wash on some renderers).
// Quarter divider verticals always render visibly regardless of bg opacity —
// pinned to a moderate gray that shows on both light and dark themes.
// Resolve once: theme is constant across a script run.
color HOUR_BOX_BG          = color.t(T.q_div) >= 95 ? color(na) : T.q_div
// Detect the actual chart background brightness so contrast-sensitive colors
// (text, frame borders) stay readable even if the indicator's theme input
// doesn't match the user's TradingView chart skin.
// `color.r/g/b` give 0–255; pick light text on dark bg and vice versa.
bool _CHART_IS_LIGHT       = (color.r(chart.bg_color) + color.g(chart.bg_color) + color.b(chart.bg_color)) / 3.0 > 127
color HOUR_BOX_BORDER      = _CHART_IS_LIGHT ? color.new(#475569, 70) : color.new(#cbd5e1, 70)
color HOUR_DIV_LINE        = _CHART_IS_LIGHT ? color.new(#475569, 80) : color.new(#cbd5e1, 80)
color HOUR_OPEN_COLOR      = _CHART_IS_LIGHT ? color.new(#0f172a, 0)  : color.new(#f1f5f9, 0)
color HL_MARK_COLOR        = _CHART_IS_LIGHT ? color.new(#0f172a, 0)  : color.new(#f1f5f9, 0)
color SWEEP_RED_COLOR      = gTheme == "Light" ? color.new(#dc2626, 0)  : color.new(#ef4444, 0)
color SWEEP_GREEN_COLOR    = gTheme == "Light" ? color.new(#059669, 0)  : color.new(#10b981, 0)
color DOJI_LINE_COLOR      = gTheme == "Light" ? color.new(#000000, 0)  : color.new(#ffffff, 0)
color IN_STAT_BG           = color.new(T.in_stat, 80)
color OUT_STAT_BG          = color.new(T.out_stat, 80)
color ACTIVE_TRIAD_BORDER  = color.new(T.active_triad, math.max(0, color.t(T.active_triad) - 40))
color BOX_05_BORDER        = color.new(T.box_tint, math.max(0, color.t(T.box_tint) - 10))
color ACTIVE_HR_BG         = color.t(T.active_hr) >= 95 ? color(na) : T.active_hr
color ACTIVE_HR_BORDER     = color(na)
color BAND_05_BG           = color.new(T.band_05, 100)
color BAND_10_BG           = color.new(T.band_10, 100)
color APEX_HOUR_BG         = color.new(T.apex_hour, 97)
color APEX_HOUR_BORDER     = color.new(T.apex_hour, 85)
color APEX_HOUR_LABEL_BG   = color.new(T.apex_hour, 88)
color MID_1H_BG            = color.new(T.mid_1h, 90)
color MID_3H_LINE          = color.new(T.mid_3h, 50)
color HOUR_OPEN_LABEL_BG   = color.new(HOUR_OPEN_COLOR, 100)
color HL_MARK_LABEL_BG     = color.new(HL_MARK_COLOR, 100)
color RED_TRANSPARENT      = color.new(color.red, 100)
// Formal "pill" palette for hour-close summary label. Neutral slate fill,
// solid (no transparency) so the box reads clearly against any chart bg.
color PILL_BG              = gTheme == "Light" ? color.new(#e2e8f0, 0)  : color.new(#334155, 0)
color PILL_BORDER          = gTheme == "Light" ? color.new(#94a3b8, 30) : color.new(#64748b, 30)
color PILL_TEXT            = gTheme == "Light" ? color.new(#0f172a, 0)  : color.new(#f1f5f9, 0)
// Per-quarter background border (100-alpha = invisible). qC differs per
// quarter (Q1/Q2/Q3/Q4 user-configurable), so we resolve all four.
color Q1_BG_BORDER         = color.new(gColQ1Bg, 100)
color Q2_BG_BORDER         = color.new(gColQ2Bg, 100)
color Q3_BG_BORDER         = color.new(gColQ3Bg, 100)
color Q4_BG_BORDER         = color.new(gColQ4Bg, 100)

// One box + 3 quarter-divider lines per hour, updated live as range expands
var box currentHourBox = na
var line currentQ2Line = na
var line currentQ3Line = na
var line currentQ4Line = na

// Reset / create at hour open (first bar of Q1 with valid block) — 1m only.
// Quarter divider verticals are spawned now at their predicted bar positions
// (Q2 = hourStart+15, Q3 = +30, Q4 = +45) so they're visible from hour open
// instead of appearing only as price reaches each minute.
if gQStructOn and gShowQDiv and IS_TF_MIN1 and isFirstBarOfQuarter() and quarterOfHour() == 1 and inTrackedHour()
    currentHourBox := box.new(left=bar_index, top=high, right=bar_index + BARS_PER_HOUR - 1, bottom=low,
                              xloc=xloc.bar_index, bgcolor=HOUR_BOX_BG,
                              border_color=HOUR_BOX_BORDER, border_width=2)
    currentQ2Line := line.new(bar_index + BARS_PER_QUARTER,     low, bar_index + BARS_PER_QUARTER,     high,
                              xloc=xloc.bar_index, extend=extend.none,
                              color=HOUR_DIV_LINE, style=line.style_solid, width=2)
    currentQ3Line := line.new(bar_index + BARS_PER_QUARTER * 2, low, bar_index + BARS_PER_QUARTER * 2, high,
                              xloc=xloc.bar_index, extend=extend.none,
                              color=HOUR_DIV_LINE, style=line.style_solid, width=2)
    currentQ4Line := line.new(bar_index + BARS_PER_QUARTER * 3, low, bar_index + BARS_PER_QUARTER * 3, high,
                              xloc=xloc.bar_index, extend=extend.none,
                              color=HOUR_DIV_LINE, style=line.style_solid, width=2)

// Update every bar inside the active hour: expand top/bottom to running range
if gQStructOn and gShowQDiv and isTfMin1() and not na(currentHourBox) and inTrackedHour()
    new_top    = math.max(box.get_top(currentHourBox),    high)
    new_bottom = math.min(box.get_bottom(currentHourBox), low)
    box.set_top(currentHourBox, new_top)
    box.set_bottom(currentHourBox, new_bottom)
    // Sync any existing quarter divider lines to match new top/bottom
    if not na(currentQ2Line)
        line.set_y1(currentQ2Line, new_bottom)
        line.set_y2(currentQ2Line, new_top)
    if not na(currentQ3Line)
        line.set_y1(currentQ3Line, new_bottom)
        line.set_y2(currentQ3Line, new_top)
    if not na(currentQ4Line)
        line.set_y1(currentQ4Line, new_bottom)
        line.set_y2(currentQ4Line, new_top)

// ── Per-quarter background tints ──────────────────────────────────────────
// One box per quarter, spawned at quarter open. Each box's bg color comes
// from the user-configurable per-quarter setting. Bounded vertically to the
// hour box (so they live inside the hour, not full chart height).

var box currentQ1Bg = na
var box currentQ2Bg = na
var box currentQ3Bg = na
var box currentQ4Bg = na

qBgColorFor(int qIdx) =>
    qIdx == 1 ? gColQ1Bg : qIdx == 2 ? gColQ2Bg : qIdx == 3 ? gColQ3Bg : gColQ4Bg

// Reset references at hour open so closed-hour quarter tints freeze in place
if gQStructOn and gShowQBgs and isTfMin1() and isFirstBarOfQuarter() and quarterOfHour() == 1 and inTrackedHour()
    currentQ1Bg := na
    currentQ2Bg := na
    currentQ3Bg := na
    currentQ4Bg := na

// Spawn a per-quarter bg box at the start of each quarter
// Right edge extends slightly into the next quarter (+1 bar) so adjacent
// quarter boxes overlap by 1 bar — eliminates visual seam gaps caused by
// pixel boundaries between consecutive bars on TradingView.
if gQStructOn and gShowQBgs and IS_TF_MIN1 and isFirstBarOfQuarter() and inTrackedHour() and not na(currentHourBox)
    int qNewBg = quarterOfHour()
    int qLeft  = bar_index
    int qRight = bar_index + BARS_PER_QUARTER
    color qC      = qNewBg == 1 ? gColQ1Bg     : qNewBg == 2 ? gColQ2Bg     : qNewBg == 3 ? gColQ3Bg     : gColQ4Bg
    color qBorder = qNewBg == 1 ? Q1_BG_BORDER : qNewBg == 2 ? Q2_BG_BORDER : qNewBg == 3 ? Q3_BG_BORDER : Q4_BG_BORDER
    box newQBox = box.new(qLeft, box.get_top(currentHourBox), qRight, box.get_bottom(currentHourBox),
                          xloc=xloc.bar_index, bgcolor=qC,
                          border_color=qBorder, border_width=0)
    if qNewBg == 1
        currentQ1Bg := newQBox
    if qNewBg == 2
        currentQ2Bg := newQBox
    if qNewBg == 3
        currentQ3Bg := newQBox
    if qNewBg == 4
        currentQ4Bg := newQBox

// Sync per-quarter bg tops/bottoms to the hour box as it expands
if gQStructOn and gShowQBgs and isTfMin1() and not na(currentHourBox)
    float qBgTop = box.get_top(currentHourBox)
    float qBgBot = box.get_bottom(currentHourBox)
    if not na(currentQ1Bg)
        box.set_top(currentQ1Bg,    qBgTop)
        box.set_bottom(currentQ1Bg, qBgBot)
    if not na(currentQ2Bg)
        box.set_top(currentQ2Bg,    qBgTop)
        box.set_bottom(currentQ2Bg, qBgBot)
    if not na(currentQ3Bg)
        box.set_top(currentQ3Bg,    qBgTop)
        box.set_bottom(currentQ3Bg, qBgBot)
    if not na(currentQ4Bg)
        box.set_top(currentQ4Bg,    qBgTop)
        box.set_bottom(currentQ4Bg, qBgBot)

// ── 05-box (bounded to box range, extends horizontally across the hour) ──
// One box, anchored to the active hour's box high/low. Box high/low is locked
// at minute :04; the rectangle extends horizontally to the end of the hour.
var box current05Box = na

if gBoxOn and gShowBoxCol and isFirstBarOfQuarter() and quarterOfHour() == 1 and inTrackedHour()
    current05Box := box.new(left=bar_index, top=high, right=bar_index + BARS_PER_HOUR - 1, bottom=low,
                            xloc=xloc.bar_index, bgcolor=T.box_tint,
                            border_color=BOX_05_BORDER,
                            border_width=1, border_style=line.style_solid)

// Update 05-box bounds during minutes :00–:04 (box high/low locks after :04)
if gBoxOn and gShowBoxCol and isBoxBar() and not na(current05Box) and inTrackedHour()
    new_top_05    = math.max(box.get_top(current05Box),    high)
    new_bottom_05 = math.min(box.get_bottom(current05Box), low)
    box.set_top(current05Box, new_top_05)
    box.set_bottom(current05Box, new_bottom_05)

// ── ±0.05% / ±0.10% bands (drawn on the :04 minute when box locks) ────────
bandLevels(float boxHi, float boxLo) =>
    [boxHi * 1.0010, boxHi * 1.0005, boxLo * 0.9995, boxLo * 0.9990]

if gBoxOn and hasLiveHour()
    HourAgg curH = liveHour()
    if not na(curH) and curH.box05Locked and _M == 4 and not na(curH.box05Hi)
        [u10, u05, l05_, l10] = bandLevels(curH.box05Hi, curH.box05Lo)
        int hourStartBar = curH.anchorBar
        // Bands extend only through the rest of Q1 — i.e. up to and including
        // minute :14 of the hour. They are NOT drawn through Q2/Q3/Q4.
        int q1EndBar = curH.anchorBar + BARS_PER_QUARTER - 1
        if gShowBand10
            line.new(hourStartBar, u10, q1EndBar, u10, xloc=xloc.bar_index, color=T.band_10, style=line.style_dotted, width=2)
            line.new(hourStartBar, l10, q1EndBar, l10, xloc=xloc.bar_index, color=T.band_10, style=line.style_dotted, width=2)
            if gShowBandLbl
                label.new(q1EndBar, u10, ".1%", xloc=xloc.bar_index, color=BAND_10_BG, textcolor=T.band_10, style=label.style_label_left, size=size.small)
                label.new(q1EndBar, l10, ".1%", xloc=xloc.bar_index, color=BAND_10_BG, textcolor=T.band_10, style=label.style_label_left, size=size.small)
        if gShowBand05
            line.new(hourStartBar, u05, q1EndBar, u05, xloc=xloc.bar_index, color=T.band_05, style=line.style_dotted, width=1)
            line.new(hourStartBar, l05_, q1EndBar, l05_, xloc=xloc.bar_index, color=T.band_05, style=line.style_dotted, width=1)
            if gShowBandLbl
                label.new(q1EndBar, u05, ".05%", xloc=xloc.bar_index, color=BAND_05_BG, textcolor=T.band_05, style=label.style_label_left, size=size.small)
                label.new(q1EndBar, l05_, ".05%", xloc=xloc.bar_index, color=BAND_05_BG, textcolor=T.band_05, style=label.style_label_left, size=size.small)

// ── Band rejection markers ────────────────────────────────────────────────
detectBandRejection(float h, float l, float c, float u10, float u05, float l05_, float l10) =>
    string side = "", level = ""
    if h > u10 and c < u10
        side := "upper"
        level := "10"
    else if h > u05 and c < u05
        side := "upper"
        level := "05"
    else if l < l10 and c > l10
        side := "lower"
        level := "10"
    else if l < l05_ and c > l05_
        side := "lower"
        level := "05"
    [side, level]

var string boxReactState = "none"
// Per-band first-rejection flags. Reset at hour open, set true after first hit.
var bool rejFired10Up = false
var bool rejFired10Dn = false
var bool rejFired05Up = false
var bool rejFired05Dn = false

if gBoxOn and hasLiveHour()
    HourAgg curH_br = liveHour()
    if not na(curH_br) and curH_br.box05Locked and not na(curH_br.box05Hi)
        [u10b, u05b, l05b, l10b] = bandLevels(curH_br.box05Hi, curH_br.box05Lo)
        [side, level] = detectBandRejection(high, low, close, u10b, u05b, l05b, l10b)
        if side != ""
            // Update box-react state used in readouts
            string token = level + (side == "upper" ? "up_rejected" : "dn_rejected")
            if boxReactState == "none" or boxReactState == token
                boxReactState := token
            else
                boxReactState := "multi"

            // Only mark the FIRST rejection of each (level, side) per hour.
            bool isFirst = (level == "10" and side == "upper" and not rejFired10Up) or
                           (level == "10" and side == "lower" and not rejFired10Dn) or
                           (level == "05" and side == "upper" and not rejFired05Up) or
                           (level == "05" and side == "lower" and not rejFired05Dn)

            if isFirst
                if level == "10" and side == "upper"
                    rejFired10Up := true
                if level == "10" and side == "lower"
                    rejFired10Dn := true
                if level == "05" and side == "upper"
                    rejFired05Up := true
                if level == "05" and side == "lower"
                    rejFired05Dn := true

                // Only render the 10% band rejections; 05% rejections suppressed.
                if gShowBandRej and level == "10"
                    color cMark = T.band_10
                    float anchorY = side == "upper" ? high : low
                    label.new(bar_index, anchorY, "rej " + level,
                              style=side == "upper" ? label.style_label_down : label.style_label_up,
                              color=color.new(cMark, 95), textcolor=cMark, size=size.small)
                if gAlertsOn and gAlertBandRej
                    alert("Live Price Action: " + level + "% band " + side + " rejection", alert.freq_once_per_bar)

// Reset per-hour state at hour open
if isFirstBarOfQuarter() and quarterOfHour() == 1
    boxReactState := "none"
    rejFired10Up := false
    rejFired10Dn := false
    rejFired05Up := false
    rejFired05Dn := false

// ── 1h midline + reactions ────────────────────────────────────────────────
resolve1hMid(HourAgg cur, HourAgg prior) =>
    float mid = na
    string source = "current"
    if not na(cur)
        curHi = hourHigh(cur)
        curLo = hourLow(cur)
        if not na(curHi) and not na(curLo)
            if not na(prior)
                prHi = hourHigh(prior)
                prLo = hourLow(prior)
                if not na(prHi) and not na(prLo) and curLo > prLo and curHi < prHi
                    mid := (prHi + prLo) / 2.0
                    source := "prior"
                else
                    mid := (curHi + curLo) / 2.0
            else
                mid := (curHi + curLo) / 2.0
    [mid, source]

resolve3hMid(TriadAgg cur, float priorTriadHi, float priorTriadLo) =>
    float mid = na
    string source = "current"
    if not na(cur)
        curHi = triadHigh(cur)
        curLo = triadLow(cur)
        if not na(curHi) and not na(curLo)
            if not na(priorTriadHi) and not na(priorTriadLo) and curLo > priorTriadLo and curHi < priorTriadHi
                mid := (priorTriadHi + priorTriadLo) / 2.0
                source := "prior"
            else
                mid := (curHi + curLo) / 2.0
    [mid, source]

detectMidReaction(float mid, float h, float l, float c) =>
    string r = ""
    if not na(mid)
        if l < mid and c > mid
            r := "support"
        else if h > mid and c < mid
            r := "reject"
    r

var HourAgg priorHour1h = na
var float priorTriadHi  = na
var float priorTriadLo  = na
var string midhrState   = "untouched"
var string mid3hState   = "untouched"
var string lastMidhrReaction = "none"   // dedup
var string lastMid3hReaction = "none"

// Reset on hour and triad rollovers
if isFirstBarOfQuarter() and quarterOfHour() == 1
    midhrState := "untouched"
    lastMidhrReaction := "none"
if isFirstBarOfQuarter() and quarterOfHour() == 1 and hourIndexInTriad() == 1
    mid3hState := "untouched"
    lastMid3hReaction := "none"

// Compute current 1h mid + reaction
float curMid1h = na
if hasLiveHour()
    HourAgg curH_m = liveHour()
    if not na(curH_m)
        [m1, _src1] = resolve1hMid(curH_m, priorHour1h)
        curMid1h := m1
        if not na(curMid1h)
            r1 = detectMidReaction(curMid1h, high, low, close)
            if r1 != "" and r1 != lastMidhrReaction
                midhrState := r1
                lastMidhrReaction := r1
                if gMidOn and gShowMidReact
                    if r1 == "support"
                        label.new(bar_index, low, "●", style=label.style_label_up,
                                  color=MID_1H_BG, textcolor=T.mid_1h, size=size.small)
                    else
                        label.new(bar_index, high, "●", style=label.style_label_down,
                                  color=MID_1H_BG, textcolor=T.mid_1h, size=size.small)
                if gAlertsOn and gAlertMid
                    alert("Live Price Action: 1h midline " + r1, alert.freq_once_per_bar)

// Compute current 3h mid + reaction
float curMid3h = na
if not na(activeTriad)
    [m3, _src3] = resolve3hMid(activeTriad, priorTriadHi, priorTriadLo)
    curMid3h := m3
    if not na(curMid3h)
        r3 = detectMidReaction(curMid3h, high, low, close)
        if r3 != "" and r3 != lastMid3hReaction
            mid3hState := r3
            lastMid3hReaction := r3
            // (Same alert path as 1h, no separate marker by default)
            if gAlertsOn and gAlertMid
                alert("Live Price Action: 3h midline " + r3, alert.freq_once_per_bar)

// Draw midlines as ONE line per hour (1h) and ONE per triad (3h), updated
// in-place as the running mid drifts. New objects spawn at hour/triad open.
var line currentMid1hLine = na
var line currentMid3hLine = na

// Reset / spawn 1h midline at hour open
if gMidOn and gShowMid1h and isFirstBarOfQuarter() and quarterOfHour() == 1 and inTrackedHour()
    currentMid1hLine := line.new(bar_index, na, bar_index + BARS_PER_HOUR - 1, na,
                                 xloc=xloc.bar_index, color=T.mid_1h,
                                 width=gMid1hWidth, style=line.style_solid)

// Reset / spawn 3h midline at triad open (first bar of C1)
// Lazy-spawn fallback: if activeTriad exists but no line yet (chart loaded
// mid-block), create one anchored at the triad's start bar.
// 3h midline is solid; right-edge tracks the current bar (not the full triad).
if gMidOn and gShowMid3h and isFirstBarOfQuarter() and quarterOfHour() == 1 and hourIndexInTriad() == 1 and not na(blockId())
    currentMid3hLine := line.new(bar_index, na, bar_index, na,
                                 xloc=xloc.bar_index, color=MID_3H_LINE,
                                 width=gMid3hWidth, style=line.style_solid)
else if gMidOn and gShowMid3h and not na(activeTriad) and na(currentMid3hLine)
    currentMid3hLine := line.new(activeTriad.anchorBar, na, activeTriad.anchorBar, na,
                                 xloc=xloc.bar_index, color=MID_3H_LINE,
                                 width=gMid3hWidth, style=line.style_solid)

// Update y-coords each bar so the line follows the running mid; extend the
// 3h line's right edge to the current bar so it grows with the active triad.
if gMidOn and gShowMid1h and not na(currentMid1hLine) and not na(curMid1h)
    line.set_y1(currentMid1hLine, curMid1h)
    line.set_y2(currentMid1hLine, curMid1h)

if gMidOn and gShowMid3h and not na(currentMid3hLine) and not na(curMid3h) and not na(activeTriad)
    line.set_y1(currentMid3hLine, curMid3h)
    line.set_y2(currentMid3hLine, curMid3h)
    // Clamp right edge to the triad's last bar so the line doesn't extend
    // past the triad close (e.g. the 12-15 triad's midline shouldn't reach
    // beyond 14:59, the :59 of the triad's third hour).
    int triadEndBar = activeTriad.anchorBar + 3 * BARS_PER_HOUR - 1
    line.set_x2(currentMid3hLine, math.min(bar_index, triadEndBar))


// ── Sweepers + bias-shifts + doji-confirmed ───────────────────────────────
// Also returns the price and bar of the EXTREME that was broken by `byQ`.
// When newBias==1 (high taken out), brokenLevel = the broken target high.
// When newBias==-1 (low taken out), brokenLevel = the broken target low.
// Used to draw the doji-confirmation line at the actual broken price level.
// Returns: events string, took-high flag, took-low flag, broken hi/lo.
// Caller decides whether to flip bias based on prior state — if the quarter
// took both sides, that's a full range expansion, not a no-op.
detectSweepsForQuarter(HourAgg h, int byQ) =>
    string events = ""
    bool tookHigh = false
    bool tookLow  = false
    float brokenHi = na
    float brokenLo = na
    QuarterAgg byQuarter = byQ == 2 ? h.q2 : byQ == 3 ? h.q3 : h.q4
    if not na(byQuarter)
        for tQ = 1 to byQ - 1
            QuarterAgg targ = tQ == 1 ? h.q1 : tQ == 2 ? h.q2 : h.q3
            if not na(targ)
                if byQuarter.high_ > targ.high_
                    events := events + "Q" + str.tostring(int(byQ)) + "→Q" + str.tostring(int(tQ)) + " high  "
                    tookHigh := true
                    if na(brokenHi) or targ.high_ > brokenHi
                        brokenHi := targ.high_
                if byQuarter.low_ < targ.low_
                    events := events + "Q" + str.tostring(int(byQ)) + "→Q" + str.tostring(int(tQ)) + " low  "
                    tookLow := true
                    if na(brokenLo) or targ.low_ < brokenLo
                        brokenLo := targ.low_
    [events, tookHigh, tookLow, brokenHi, brokenLo]

var int  lastSweepBias    = 0
var int  lastSweepBiasBar = na  // bar_index where lastSweepBias was last set
var bool dojiConfirmedThisHour = false

if isFirstBarOfQuarter() and quarterOfHour() == 1
    lastSweepBias    := 0
    lastSweepBiasBar := na
    dojiConfirmedThisHour := false

if gQStructOn and isLastBarOfQuarter() and hasLiveHour()
    HourAgg curH_sw = liveHour()
    int byQ = quarterOfHour()
    if not na(curH_sw) and byQ >= 2
        [events, tookHigh, tookLow, brokenHi, brokenLo] = detectSweepsForQuarter(curH_sw, byQ)
        if events != ""
            // Doji-confirmed fires when the breaking quarter takes out the
            // OPPOSITE side of the hour's prior bias. If both sides were
            // taken in the same close (full range expansion), that also
            // counts as a flip vs whichever side the prior bias was on.
            // The "side broken" for marker purposes is the side opposite
            // to the prior bias.
            int flipDir = 0
            if lastSweepBias > 0 and tookLow
                flipDir := -1
            else if lastSweepBias < 0 and tookHigh
                flipDir := 1

            if flipDir != 0 and not dojiConfirmedThisHour
                dojiConfirmedThisHour := true
                if gShowDojiConf
                    QuarterAgg byQuarter_brk = byQ == 2 ? curH_sw.q2 : byQ == 3 ? curH_sw.q3 : curH_sw.q4
                    color cLine = DOJI_LINE_COLOR
                    color cX    = SWEEP_RED_COLOR
                    // Walk targets newest-first (Q3 → Q2 → Q1) and pick
                    // the most-recent broken quarter on the flip side.
                    int firstLeftBar = na
                    float firstYLevel = na
                    int firstBrokenQ  = na
                    if not na(byQuarter_brk)
                        for tQ_brk = byQ - 1 to 1
                            QuarterAgg targ_brk = tQ_brk == 1 ? curH_sw.q1 : tQ_brk == 2 ? curH_sw.q2 : curH_sw.q3
                            if not na(targ_brk) and na(firstLeftBar)
                                if flipDir < 0 and byQuarter_brk.low_ < targ_brk.low_
                                    firstLeftBar := targ_brk.lowBar
                                    firstYLevel  := targ_brk.low_
                                    firstBrokenQ := tQ_brk
                                if flipDir > 0 and byQuarter_brk.high_ > targ_brk.high_
                                    firstLeftBar := targ_brk.highBar
                                    firstYLevel  := targ_brk.high_
                                    firstBrokenQ := tQ_brk
                    if not na(firstLeftBar) and not na(firstYLevel)
                        int rBar = flipDir < 0 ? byQuarter_brk.lowBar : byQuarter_brk.highBar
                        line.new(firstLeftBar, firstYLevel, rBar, firstYLevel,
                                 xloc=xloc.bar_index,
                                 color=cLine, style=line.style_solid, width=1)
                        int mBar = math.round((firstLeftBar + rBar) / 2.0)
                        label.new(mBar, firstYLevel, "✕", xloc=xloc.bar_index,
                                  style=label.style_none,
                                  color=RED_TRANSPARENT,
                                  textcolor=cX, size=size.normal,
                                  tooltip="Q" + str.tostring(byQ) + " broke Q" + str.tostring(firstBrokenQ) + (flipDir < 0 ? " low" : " high") + " — doji-confirmed")
                if gAlertsOn and gAlertDoji
                    alert("Live Price Action: doji-confirmed in current hour", alert.freq_once_per_bar)

            // Update lastSweepBias: prefer continuation of prior bias if
            // both sides were taken; otherwise pick whichever side fired.
            int newBias = 0
            if tookHigh and not tookLow
                newBias := 1
            else if tookLow and not tookHigh
                newBias := -1
            else if tookHigh and tookLow
                // Both sides taken — bias direction is ambiguous; preserve
                // whichever existed previously (so a Q4 full-range expansion
                // doesn't reset the bias state mid-hour).
                newBias := lastSweepBias
            if newBias != 0
                lastSweepBias    := newBias
                lastSweepBiasBar := bar_index

            if gAlertsOn and gAlertSweep
                alert("Live Price Action: sweeper Q" + str.tostring(int(byQ)), alert.freq_once_per_bar)


// ── Live extreme lines (high/low markers, no labels) ─────────────────────
// Two horizontal lines per hour, anchored at the candle that currently holds
// the hour's high/low and extending right to :59. Updated in-place every
// bar. The corresponding text labels (in-stat / out-of-stat) are rendered
// once at hour close as a single centered label on top of the hour box.

var line liveHighLine = na
var line liveLowLine  = na

if gQStructOn and isTfMin1() and isFirstBarOfQuarter() and quarterOfHour() == 1 and inTrackedHour()
    liveHighLine := na
    liveLowLine  := na

if gQStructOn and isTfMin1() and hasLiveHour()
    HourAgg curH_live = liveHour()
    if not na(curH_live)
        float curHi = hourHigh(curH_live)
        float curLo = hourLow(curH_live)
        if not na(curHi) and not na(curLo)
            QuarterAgg qHiL = na
            QuarterAgg qLoL = na
            float epsL = extremeEps()
            for q_idx_l = 1 to 4
                QuarterAgg qxL = q_idx_l == 1 ? curH_live.q1 : q_idx_l == 2 ? curH_live.q2 : q_idx_l == 3 ? curH_live.q3 : curH_live.q4
                if not na(qxL)
                    if na(qHiL) and qxL.high_ >= curHi - epsL
                        qHiL := qxL
                    if na(qLoL) and qxL.low_ <= curLo + epsL
                        qLoL := qxL
            int hourEndBarLive = curH_live.anchorBar + BARS_PER_HOUR - 1

            if not na(qHiL)
                if na(liveHighLine)
                    liveHighLine := line.new(qHiL.highBar, qHiL.high_, hourEndBarLive, qHiL.high_,
                                             xloc=xloc.bar_index, color=HL_MARK_COLOR,
                                             style=line.style_solid, width=1)
                else
                    line.set_xy1(liveHighLine, qHiL.highBar, qHiL.high_)
                    line.set_xy2(liveHighLine, hourEndBarLive, qHiL.high_)

            if not na(qLoL)
                if na(liveLowLine)
                    liveLowLine := line.new(qLoL.lowBar, qLoL.low_, hourEndBarLive, qLoL.low_,
                                            xloc=xloc.bar_index, color=HL_MARK_COLOR,
                                            style=line.style_solid, width=1)
                else
                    line.set_xy1(liveLowLine, qLoL.lowBar, qLoL.low_)
                    line.set_xy2(liveLowLine, hourEndBarLive, qLoL.low_)


// Release line refs at hour close so the next hour spawns fresh ones.
if gQStructOn and isTfMin1() and isHourClose() and hasLiveHour()
    liveHighLine := na
    liveLowLine  := na


// ── Hour-open line (live, extends to current bar) ─────────────────────────
// Solid horizontal line at the open price of the hour, labelled "XXam Open".
// One line + one label per hour, both updated in-place every bar so the line
// extends to the current bar and the label sits at its right edge.

format12h(int h24) =>
    int h12 = h24 % 12 == 0 ? 12 : h24 % 12
    string suffix = h24 < 12 ? "am" : "pm"
    str.tostring(h12) + suffix

// Track current + previous hour's open line/label so older ones get deleted
// — only the two most-recent hours' open markers stay visible.
var line  currentHourOpenLine  = na
var label currentHourOpenLabel = na
var line  priorHourOpenLine    = na
var label priorHourOpenLabel   = na

if gQStructOn and isFirstBarOfQuarter() and quarterOfHour() == 1 and inTrackedHour()
    // Shift current → prior, delete the older "prior" before overwriting.
    if not na(priorHourOpenLine)
        line.delete(priorHourOpenLine)
    if not na(priorHourOpenLabel)
        label.delete(priorHourOpenLabel)
    priorHourOpenLine  := currentHourOpenLine
    priorHourOpenLabel := currentHourOpenLabel
    string hourTag = format12h(_H)
    int hourEndBarOpen = bar_index + BARS_PER_HOUR - 1
    currentHourOpenLine := line.new(bar_index, open, hourEndBarOpen, open,
                                    xloc=xloc.bar_index, color=HOUR_OPEN_COLOR,
                                    style=line.style_solid, width=2)
    int hourMidBarOpen = bar_index + BARS_PER_HOUR / 2
    currentHourOpenLabel := label.new(hourMidBarOpen, open, hourTag + " Open",
                                      xloc=xloc.bar_index, style=label.style_label_down,
                                      color=HOUR_OPEN_LABEL_BG, textcolor=HOUR_OPEN_COLOR, size=size.small)


// ── Hour high/low marker (whichever is closer to current close) ───────────
// At hour close, draw a horizontal line from the candle that printed the
// hour's extreme to the closing bar, labelled "XXam High" or "XXam Low".
// Selection: whichever extreme is **closer in price to the closing bar's close**
// — that's the "active" reference the next hour is most likely to revisit.
//
// Sweep recolor: while the marker is live (next hour), if price pierces the
// level and closes back inside, recolor the line + label — red for a swept
// high, green for a swept low. Once recolored, the state is sticky.

// Persistent refs for the most-recently-drawn hour H/L marker so the sweep
// detector below can recolor it during the following hour.
// Plus a "prior" pair so we can keep the previous hour's marker visible
// alongside the current one — older markers get deleted when shifted out.
var line  hlLine   = na
var label hlLabel  = na
var float hlLevel  = na
var bool  hlIsHigh = false  // true → high marker; false → low marker
var bool  hlSwept  = false  // sticky once a sweep+reclose is detected
var line  hlLinePrev  = na
var label hlLabelPrev = na

if gQStructOn and isHourClose() and hasLiveHour()
    HourAgg justClosedHL = liveHour()
    if not na(justClosedHL)
        float hi = hourHigh(justClosedHL)
        float lo = hourLow(justClosedHL)
        if not na(hi) and not na(lo)
            // Find earliest quarter holding the extremes (within one tick)
            QuarterAgg qHiHL = na
            QuarterAgg qLoHL = na
            float epsHL = extremeEps()
            for q_idx_hl = 1 to 4
                QuarterAgg qxHL = q_idx_hl == 1 ? justClosedHL.q1 : q_idx_hl == 2 ? justClosedHL.q2 : q_idx_hl == 3 ? justClosedHL.q3 : justClosedHL.q4
                if not na(qxHL)
                    if na(qHiHL) and qxHL.high_ >= hi - epsHL
                        qHiHL := qxHL
                    if na(qLoHL) and qxHL.low_ <= lo + epsHL
                        qLoHL := qxHL

            // Pick whichever extreme is closer to current close
            float distToHi = math.abs(close - hi)
            float distToLo = math.abs(close - lo)
            bool useHigh = distToHi <= distToLo

            // Tag uses the just-closed hour. This fires on the :59 bar of that hour.
            string hlTag = format12h(_H)

            // Extend the H/L line through :59 of the next hour. The current bar
            // is the :59 close of the just-closed hour, so a full hour (60 mins)
            // forward lands on the :59 bar of the next hour.
            int hlEndBar = bar_index + BARS_PER_HOUR

            // Shift current → prior and drop the older prior so only the
            // last two hour H/L markers remain on the chart.
            if not na(hlLinePrev)
                line.delete(hlLinePrev)
            if not na(hlLabelPrev)
                label.delete(hlLabelPrev)
            hlLinePrev  := hlLine
            hlLabelPrev := hlLabel

            // Reset sweep state for the new marker
            hlSwept := false
            hlLine  := na
            hlLabel := na
            hlLevel := na

            if useHigh and not na(qHiHL)
                hlLine := line.new(qHiHL.highBar, hi, hlEndBar, hi, xloc=xloc.bar_index,
                                   color=HL_MARK_COLOR, style=line.style_solid, width=1)
                // Centered above the line: anchor at the midpoint of the
                // line span with style_label_down so the box floats above.
                int hlMidBar = math.round((qHiHL.highBar + hlEndBar) / 2.0)
                hlLabel := label.new(hlMidBar, hi, hlTag + " High",
                                     xloc=xloc.bar_index, style=label.style_label_down,
                                     color=HL_MARK_LABEL_BG, textcolor=HL_MARK_COLOR, size=size.small)
                hlLevel := hi
                hlIsHigh := true
            else if not na(qLoHL)
                hlLine := line.new(qLoHL.lowBar, lo, hlEndBar, lo, xloc=xloc.bar_index,
                                   color=HL_MARK_COLOR, style=line.style_solid, width=1)
                // Centered above the line.
                int hlMidBar = math.round((qLoHL.lowBar + hlEndBar) / 2.0)
                hlLabel := label.new(hlMidBar, lo, hlTag + " Low",
                                     xloc=xloc.bar_index, style=label.style_label_down,
                                     color=HL_MARK_LABEL_BG, textcolor=HL_MARK_COLOR, size=size.small)
                hlLevel := lo
                hlIsHigh := false

// Sweep + reclose detector. Runs every bar while a live marker exists and
// hasn't already been flagged. High swept → red; low swept → green.
if gQStructOn and not hlSwept and not na(hlLine) and not na(hlLevel)
    bool fired = false
    color cSwept = na
    if hlIsHigh and high > hlLevel and close < hlLevel
        fired := true
        cSwept := SWEEP_RED_COLOR
    else if not hlIsHigh and low < hlLevel and close > hlLevel
        fired := true
        cSwept := SWEEP_GREEN_COLOR
    if fired
        line.set_color(hlLine, cSwept)
        if not na(hlLabel)
            label.set_textcolor(hlLabel, cSwept)
        hlSwept := true


// ── Hour close summary label ──────────────────────────────────────────────
// One label per closed hour, centered horizontally on top of the hour box.
// Combines the stat-tagged extremes (Q# in-stat / out-of-stat high/low) and
// the hour classifier (line-up / line-down / doji).
//
// Stat rule: a quarter's extreme is only labelled when a *later* quarter has
// taken the holder's *opposite* side. If Q1 holds both high+low and nothing
// breaks Q1's range, no stat tag fires. If Q2 takes Q1's high → Q2 = out-of-
// stat high, Q1 retains the low → Q1 = in-stat low.
quartersFor(HourAgg h, int idx) =>
    QuarterAgg q = idx == 1 ? h.q1 : idx == 2 ? h.q2 : idx == 3 ? h.q3 : h.q4
    q

// True when some OTHER quarter (any qIdx != holderIdx) has a low strictly
// below `holderLow`. Confirms the hour's range extended past the holder's
// own low → the high holder isn't trivial.
brokeBelow(HourAgg h, int holderIdx, float holderLow) =>
    bool broke = false
    for j = 1 to 4
        if j != holderIdx
            QuarterAgg qj = quartersFor(h, j)
            if not na(qj) and qj.low_ < holderLow
                broke := true
    broke

brokeAbove(HourAgg h, int holderIdx, float holderHigh) =>
    bool broke = false
    for j = 1 to 4
        if j != holderIdx
            QuarterAgg qj = quartersFor(h, j)
            if not na(qj) and qj.high_ > holderHigh
                broke := true
    broke

// Track the most recent hour-close pill so we can delete it when the next
// hour closes — only the current (most recent) hour's pill should be visible.
var label hourSummaryLabel = na

if gVerdictsOn and gShowHourVerd and isHourClose() and hasLiveHour()
    HourAgg justClosedV = liveHour()
    if not na(justClosedV)
        // Drop the prior hour's pill before drawing this one.
        if not na(hourSummaryLabel)
            label.delete(hourSummaryLabel)
            hourSummaryLabel := na
        float hiV = hourHigh(justClosedV)
        float loV = hourLow(justClosedV)
        // Latest quarter that actually prints the hour's extreme. Strict
        // equality (no eps fuzz) — we don't want an early Q1 that happens
        // to come within 1 tick of a later real high to steal the high
        // holder slot, leaving the same quarter holding both extremes
        // (which would prevent the opposite-side-break confirmation).
        QuarterAgg qHiV = na
        QuarterAgg qLoV = na
        for qi = 4 to 1
            QuarterAgg qxV = quartersFor(justClosedV, qi)
            if not na(qxV)
                if na(qHiV) and not na(hiV) and qxV.high_ == hiV
                    qHiV := qxV
                if na(qLoV) and not na(loV) and qxV.low_ == loV
                    qLoV := qxV

        // Apply stat rule: high holder's tag depends on whether some later
        // quarter broke the holder's LOW (confirming the hour moved past it).
        // Symmetrically for low holder.
        string hiTag = ""
        bool   hasHiTag = false
        if not na(qHiV) and brokeBelow(justClosedV, qHiV.qIdx, qHiV.low_)
            bool hiInStat = qHiV.qIdx == 1 or qHiV.qIdx == 4
            hiTag := "• Q" + str.tostring(qHiV.qIdx) + (hiInStat ? " In Stat High" : " Out of Stat High")
            hasHiTag := true
        string loTag = ""
        bool   hasLoTag = false
        if not na(qLoV) and brokeAbove(justClosedV, qLoV.qIdx, qLoV.high_)
            bool loInStat = qLoV.qIdx == 1 or qLoV.qIdx == 4
            loTag := "• Q" + str.tostring(qLoV.qIdx) + (loInStat ? " In Stat Low" : " Out of Stat Low")
            hasLoTag := true

        cls = classifyHour(justClosedV)
        string clsTag = cls == "doji" ? "• Doji Hour" : ""

        // Compose multi-line label: low / high / doji, each on its own line.
        // Apex hour line is appended later only when the apex case fires
        // (handled in the triad close block below — separate label).
        //
        // Left-alignment trick: anchor the label at the hour box's left edge
        // and use style_label_lower_right so the label box extends RIGHT
        // from the anchor — text inside is then visually left-flush against
        // the box's left edge. Internal padding is added via leading spaces
        // on every line and blank top/bottom lines.
        bool showStats = gShowInStat or gShowOutStat
        string parts = ""
        if hasLoTag and showStats
            parts := loTag
        if hasHiTag and showStats
            parts := parts == "" ? hiTag : parts + "\n" + hiTag
        if clsTag != ""
            parts := parts == "" ? clsTag : parts + "\n" + clsTag

        if parts != ""
            int midBar    = justClosedV.anchorBar + BARS_PER_HOUR / 2
            float topY    = not na(currentHourBox) ? box.get_top(currentHourBox) : hiV
            float labelY  = topY + atrOffset() * 0.15
            hourSummaryLabel := label.new(midBar, labelY, parts, xloc=xloc.bar_index,
                      style=label.style_label_down, color=PILL_BG,
                      textcolor=PILL_TEXT, size=size.small)


// ── Triad close verdicts + apex-hour highlight ────────────────────────────
if gVerdictsOn and isTriadClose() and not na(activeTriad)
    cls_t = classifyTriad(activeTriad)
    if cls_t != "pending"
        color ct = cls_t == "line-up" ? T.line_up :
                   cls_t == "line-down" ? T.line_dn :
                   cls_t == "apex-up" ? T.apex_up :
                   cls_t == "apex-down" ? T.apex_dn :
                   T.doji
        // Show line/apex triad verdicts only — doji triads are not labelled.
        if gShowTriadVerd and cls_t != "doji"
            label.new(bar_index, triadLow(activeTriad), cls_t + " triad", xloc=xloc.bar_index,
                      style=label.style_label_up, color=color.new(ct, 88),
                      textcolor=ct, size=size.small)
        if gShowApexHr and (cls_t == "apex-up" or cls_t == "apex-down") and not na(activeTriad.c2)
            int c2Q1Bar = na(activeTriad.c2.q1) ? activeTriad.c2.anchorBar : activeTriad.c2.q1.anchorBar
            int c2Q4Bar = na(activeTriad.c2.q4) ? bar_index : activeTriad.c2.q4.anchorBar + 14
            float c2Hi = hourHigh(activeTriad.c2)
            float c2Lo = hourLow(activeTriad.c2)
            box.new(c2Q1Bar, c2Hi, c2Q4Bar, c2Lo,
                    xloc=xloc.bar_index, bgcolor=APEX_HOUR_BG,
                    border_color=APEX_HOUR_BORDER, border_width=1)
            // Centered horizontally on top of the apex hour box.
            int apexMidBar = activeTriad.c2.anchorBar + BARS_PER_HOUR / 2
            label.new(apexMidBar, c2Hi, "• Apex Hour", xloc=xloc.bar_index,
                      style=label.style_label_down, color=APEX_HOUR_LABEL_BG,
                      textcolor=T.apex_hour, size=size.small)
        if gAlertsOn and gAlertApex and (cls_t == "apex-up" or cls_t == "apex-down")
            alert("Live Price Action: " + cls_t + " confirmed for triad " + activeTriad.blockId, alert.freq_once_per_bar)


// ── Save prior hour / prior triad on close ────────────────────────────────
if isHourClose() and hasLiveHour()
    priorHour1h := liveHour()
if isTriadClose() and not na(activeTriad)
    priorTriadHi := triadHigh(activeTriad)
    priorTriadLo := triadLow(activeTriad)


// ── Active hour & triad tints (bounded to their respective ranges) ────────
// Use box.set_* on a single box per scope so the box dimensions update
// in-place every bar — preventing a stale box from being shown when
// triad/hour high/low expand into new territory.
var box activeHourTint = na
var box activeTriadTint = na

// At hour/triad open, drop the reference (so existing closed-block boxes
// freeze in place) and spawn a fresh one in the update block below.
if isFirstBarOfQuarter() and quarterOfHour() == 1 and inTrackedHour()
    activeHourTint := na
if isFirstBarOfQuarter() and quarterOfHour() == 1 and hourIndexInTriad() == 1 and not na(blockId())
    activeTriadTint := na

// If toggle flipped off mid-session, delete the existing visible box.
if not gShow1h and not na(activeHourTint)
    box.delete(activeHourTint)
    activeHourTint := na
if not gShow3h and not na(activeTriadTint)
    box.delete(activeTriadTint)
    activeTriadTint := na

// Active hour tint: works for triad hours AND the 3pm standalone hour.
if isTfMin1or5() and hasLiveHour()
    HourAgg curH_t = liveHour()

    // Active hour: bounded to current hour's running high/low
    if gShow1h and not na(curH_t)
        float curHi = hourHigh(curH_t)
        float curLo = hourLow(curH_t)
        if not na(curHi) and not na(curLo)
            if na(activeHourTint)
                activeHourTint := box.new(curH_t.anchorBar, curHi, bar_index, curLo,
                                          xloc=xloc.bar_index, bgcolor=ACTIVE_HR_BG,
                                          border_color=ACTIVE_HR_BORDER, border_width=0)
            else
                box.set_left(activeHourTint, curH_t.anchorBar)
                box.set_right(activeHourTint, bar_index)
                box.set_top(activeHourTint, curHi)
                box.set_bottom(activeHourTint, curLo)

// Active triad tint: triad-only (no 3pm). Skipped during 3pm hour.
if isTfMin1or5() and not na(activeTriad)
    if gShow3h
        float trHi = triadHigh(activeTriad)
        float trLo = triadLow(activeTriad)
        if not na(trHi) and not na(trLo)
            if na(activeTriadTint)
                activeTriadTint := box.new(activeTriad.anchorBar, trHi, bar_index, trLo,
                                           xloc=xloc.bar_index, bgcolor=T.active_triad,
                                           border_color=ACTIVE_TRIAD_BORDER,
                                           border_width=2)
            else
                box.set_left(activeTriadTint, activeTriad.anchorBar)
                box.set_right(activeTriadTint, bar_index)
                box.set_top(activeTriadTint, trHi)
                box.set_bottom(activeTriadTint, trLo)



