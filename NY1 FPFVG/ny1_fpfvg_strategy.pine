// ┌─────────────────────────────────────────────────────────────────────────────┐
// │  NY1 F.P.FVG — Forward Test Strategy                                       │
// │  Matches ny1_backtest.py exactly:                                           │
// │    • C2 = anchor candle (9:31–9:59 ET); C1 = bar before, C3 = bar after   │
// │    • Bullish FVG: C3.low > C1.high AND C2 bullish body  →  LONG           │
// │    • Bearish FVG: C3.high < C1.low  AND C2 bearish body →  SHORT          │
// │    • Entry:  limit at C3.low (LONG) / C3.high (SHORT)                     │
// │    • Stop:   min(C1.low, C2.low)  /  max(C1.high, C2.high)                │
// │    • TP1:    +10bps from entry (configurable) — default 80% of position   │
// │    • Runner: 20% held; stop moved to breakeven after TP1 fires            │
// │    • EOD:    all remaining positions closed at 16:00 ET                    │
// │                                                                             │
// │  Chart: 1-minute NQ continuous (NQ1!)                                      │
// │  Timezone: America/New_York                                                │
// └─────────────────────────────────────────────────────────────────────────────┘

//@version=5
strategy(
    title                   = "NY1 F.P.FVG — Forward Test",
    shorttitle              = "NY1 FPFVG",
    overlay                 = true,
    default_qty_type        = strategy.percent_of_equity,
    default_qty_value       = 100,
    pyramiding              = 0,
    calc_on_every_tick      = false,
    process_orders_on_close = false
)

// ─── Inputs ───────────────────────────────────────────────────────────────────
i_tp1_pct  = input.float(0.10, "TP1 Target (%)", minval=0.01, step=0.01, tooltip="TP1 target distance from entry in %. Default 0.10% = 10bps (POTQ).") / 100
i_tp1_size = input.int(80,    "TP1 Position Size (%)", minval=1, maxval=100, tooltip="% of position closed at TP1. Set to 100 for Cashflow (no runner). Default 80 = Cashflow + Extended.")
i_show_box = input.bool(true, "Show FVG Box",      group="Visuals")
i_show_lvl = input.bool(true, "Show Level Lines",  group="Visuals")
i_show_lbl = input.bool(true, "Show Signal Label", group="Visuals")

// ─── Time helpers (ET) ────────────────────────────────────────────────────────
// C2 is bar[1] — check its open time for the scan window
c2_et_h   = hour(time[1],   "America/New_York")
c2_et_m   = minute(time[1], "America/New_York")
curr_et_h = hour(time,      "America/New_York")
curr_et_m = minute(time,    "America/New_York")

in_scan  = c2_et_h == 9 and c2_et_m >= 31 and c2_et_m <= 59
at_reset = curr_et_h == 9  and curr_et_m == 30
at_eod   = curr_et_h == 16 and curr_et_m == 0

// ─── FVG Candle References ────────────────────────────────────────────────────
// C1 = bar[2]  |  C2 = bar[1]  |  C3 = current bar (just closed)
c1_hi  = high[2]
c1_lo  = low[2]
c2_hi  = high[1]
c2_lo  = low[1]
c2_bull = close[1] > open[1]

bull_fvg = low  > c1_hi and c2_bull
bear_fvg = high < c1_lo and not c2_bull

// ─── Per-day state ────────────────────────────────────────────────────────────
var bool  found        = false
var bool  exits_placed = false
var bool  tp1_done     = false
var float ent_px       = na
var float stp_px       = na
var float tp1_px       = na
var bool  is_long      = na

if at_reset
    found        := false
    exits_placed := false
    tp1_done     := false
    ent_px       := na
    stp_px       := na
    tp1_px       := na
    is_long      := na
    strategy.cancel_all()

// ─── FVG Detection & Entry Order ─────────────────────────────────────────────
sig = (bull_fvg or bear_fvg) and in_scan and not found

if sig
    found   := true
    is_long := bull_fvg
    ent_px  := bull_fvg ? low  : high
    stp_px  := bull_fvg ? math.min(c1_lo, c2_lo) : math.max(c1_hi, c2_hi)
    tp1_px  := bull_fvg ? ent_px * (1.0 + i_tp1_pct) : ent_px * (1.0 - i_tp1_pct)
    cmt     = (bull_fvg ? "▲ NY1 LONG" : "▼ NY1 SHORT") + " | SL " + str.tostring(stp_px, "#.##") + " | TP1 " + str.tostring(tp1_px, "#.##")
    if bull_fvg
        strategy.entry("L", strategy.long,  limit=ent_px, comment=cmt)
    else
        strategy.entry("S", strategy.short, limit=ent_px, comment=cmt)

// ─── Exit Management ─────────────────────────────────────────────────────────
pos          = strategy.position_size
in_pos       = pos != 0
just_entered = in_pos and not exits_placed

if just_entered
    exits_placed := true
    if is_long
        strategy.exit("SL",  "L", stop=stp_px, comment="Stop")
        strategy.exit("TP1", "L", qty_percent=i_tp1_size, limit=tp1_px, comment="TP1")
    else
        strategy.exit("SL",  "S", stop=stp_px, comment="Stop")
        strategy.exit("TP1", "S", qty_percent=i_tp1_size, limit=tp1_px, comment="TP1")

// Detect TP1 fill — position reduced but still open → move stop to breakeven
prev_pos     = strategy.position_size[1]
pos_reduced  = math.abs(pos) < math.abs(prev_pos) and math.abs(prev_pos) > 0
tp1_just_hit = exits_placed and not tp1_done and in_pos and pos_reduced

if tp1_just_hit
    tp1_done := true
    strategy.cancel("SL")
    if is_long
        strategy.exit("Runner", "L", stop=ent_px, comment="Runner BE")
    else
        strategy.exit("Runner", "S", stop=ent_px, comment="Runner BE")

if at_eod and in_pos
    strategy.close_all(comment="EOD 16:00")

if at_eod and not in_pos and found
    strategy.cancel_all()

// ─── Alert Conditions ────────────────────────────────────────────────────────
alertcondition(sig and bull_fvg, title="NY1 LONG Setup",  message="NY1 FPFVG ▲ LONG | {{ticker}} | Limit: {{plot_0}} | SL: {{plot_1}} | TP1: {{plot_2}}")
alertcondition(sig and bear_fvg, title="NY1 SHORT Setup", message="NY1 FPFVG ▼ SHORT | {{ticker}} | Limit: {{plot_0}} | SL: {{plot_1}} | TP1: {{plot_2}}")

plot(sig ? ent_px : na, "Entry", display=display.none)
plot(sig ? stp_px : na, "Stop",  display=display.none)
plot(sig ? tp1_px : na, "TP1",   display=display.none)

// ─── Visuals ──────────────────────────────────────────────────────────────────
var box  fvg_box = na
var line line_ent = na
var line line_stp = na
var line line_tp1 = na

if sig and i_show_box
    fvg_box := box.new(
        left         = bar_index - 2,
        top          = bull_fvg ? low   : c1_lo,
        right        = bar_index + 60,
        bottom       = bull_fvg ? c1_hi : high,
        border_color = bull_fvg ? color.new(color.green, 30) : color.new(color.red, 30),
        bgcolor      = bull_fvg ? color.new(color.green, 88) : color.new(color.red, 88),
        border_width = 1
    )

if sig and i_show_lvl
    line.delete(line_ent)
    line.delete(line_stp)
    line.delete(line_tp1)
    line_ent := line.new(bar_index, ent_px, bar_index + 200, ent_px, color=color.new(color.yellow, 0),  width=2, style=line.style_dashed)
    line_stp := line.new(bar_index, stp_px, bar_index + 200, stp_px, color=color.new(color.red,   15),  width=1, style=line.style_dashed)
    line_tp1 := line.new(bar_index, tp1_px, bar_index + 200, tp1_px, color=color.new(color.green, 15),  width=1, style=line.style_dashed)
    label.new(bar_index + 200, ent_px, "ENTRY", color=color.new(color.yellow, 0),  textcolor=color.black, style=label.style_label_left, size=size.tiny)
    label.new(bar_index + 200, stp_px, "STOP",  color=color.new(color.red,   15),  textcolor=color.white, style=label.style_label_left, size=size.tiny)
    label.new(bar_index + 200, tp1_px, "TP1",   color=color.new(color.green, 15),  textcolor=color.white, style=label.style_label_left, size=size.tiny)

if sig and i_show_lbl
    rr    = math.abs(tp1_px - ent_px) / math.abs(ent_px - stp_px)
    lbl_y = bull_fvg ? stp_px - math.abs(ent_px - stp_px) * 0.5 : stp_px + math.abs(stp_px - ent_px) * 0.5
    label.new(
        x         = bar_index,
        y         = lbl_y,
        text      = (bull_fvg ? "▲  LONG" : "▼  SHORT") + "\nEntry  " + str.tostring(ent_px, "#.##") + "\nStop   " + str.tostring(stp_px, "#.##") + "\nTP1    " + str.tostring(tp1_px, "#.##") + "\nR:R    1:" + str.tostring(rr, "#.##"),
        color     = bull_fvg ? color.new(color.green, 10) : color.new(color.red, 10),
        textcolor = color.white,
        style     = label.style_label_right,
        size      = size.small
    )
